<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rrhh.controlador.ReporteController" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="encabezado">
            <Label text="Reportes" styleClass="titulo-seccion" HBox.hgrow="ALWAYS" />
            <Button text="Volver al menú" onAction="#onVolver" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" alignment="TOP_LEFT" styleClass="tarjeta">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16" />
            </padding>
            <Label text="Selecciona el tipo de reporte a exportar" />
            <HBox spacing="8">
                <ComboBox fx:id="comboTipoReporte" />
                <Button text="Exportar a JSON" styleClass="button-primario" onAction="#onExportar" />
            </HBox>
            <Label fx:id="labelMensaje" wrapText="true" />
        </VBox>
    </center>
</BorderPane>
