<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rrhh.controlador.NominaController" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="encabezado">
            <Label text="Nómina" styleClass="titulo-seccion" HBox.hgrow="ALWAYS" />
            <Button text="Volver al menú" onAction="#onVolver" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16" />
            </padding>
            <HBox spacing="8" alignment="CENTER_LEFT" styleClass="tarjeta">
                <ComboBox fx:id="comboEmpleado" promptText="Empleado" />
                <ComboBox fx:id="comboMes" promptText="Mes" />
                <TextField fx:id="campoAnio" promptText="Año" prefWidth="80" />
                <TextField fx:id="campoBonoProductividad" promptText="Bono productividad" prefWidth="130" />
                <TextField fx:id="campoMinutosTardanza" promptText="Min. tardanza" prefWidth="110" />
                <Button text="Generar nómina" styleClass="button-primario" onAction="#onGenerar" />
                <Button text="Exportar historial a JSON" onAction="#onExportar" />
            </HBox>
            <TableView fx:id="tablaDetalle" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colConcepto" text="Concepto" prefWidth="260" />
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120" />
                    <TableColumn fx:id="colMonto" text="Monto" prefWidth="120" />
                </columns>
            </TableView>
            <HBox spacing="24">
                <Label fx:id="labelBruto" styleClass="kpi-etiqueta" />
                <Label fx:id="labelNeto" styleClass="kpi-etiqueta" />
            </HBox>
            <Label fx:id="labelMensaje" wrapText="true" />
        </VBox>
    </center>
</BorderPane>
