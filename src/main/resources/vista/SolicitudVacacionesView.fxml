<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rrhh.controlador.SolicitudController" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="encabezado">
            <Label text="Mis Solicitudes de Vacaciones" styleClass="titulo-seccion" HBox.hgrow="ALWAYS" />
            <Button text="Volver al menú" onAction="#onVolver" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16" />
            </padding>
            <HBox spacing="8" alignment="CENTER_LEFT" styleClass="tarjeta">
                <DatePicker fx:id="campoInicio" promptText="Fecha inicio" />
                <DatePicker fx:id="campoFin" promptText="Fecha fin" />
                <Button text="Calcular días hábiles" onAction="#onCalcularDias" />
                <Label fx:id="labelDiasHabiles" />
                <Button text="Enviar solicitud" styleClass="button-primario" onAction="#onEnviarSolicitud" />
            </HBox>
            <Label fx:id="labelMensaje" wrapText="true" />
            <TableView fx:id="tablaSolicitudes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colPeriodo" text="Periodo" prefWidth="220" />
                    <TableColumn fx:id="colDias" text="Días hábiles" prefWidth="100" />
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="120" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
