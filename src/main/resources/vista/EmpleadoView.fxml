<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rrhh.controlador.EmpleadoController" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="encabezado">
            <Label text="Gestión de Empleados" styleClass="titulo-seccion" HBox.hgrow="ALWAYS" />
            <Button text="Volver al menú" onAction="#onVolver" />
        </HBox>
    </top>
    <center>
        <HBox spacing="16">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16" />
            </padding>
            <TableView fx:id="tablaEmpleados" HBox.hgrow="ALWAYS" prefWidth="500">
                <columns>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="160" />
                    <TableColumn fx:id="colDni" text="DNI" prefWidth="90" />
                    <TableColumn fx:id="colDepartamento" text="Departamento" prefWidth="150" />
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="90" />
                </columns>
            </TableView>
            <VBox spacing="8" prefWidth="320" styleClass="tarjeta">
                <Label text="Datos del empleado" style="-fx-font-weight: bold;" />
                <TextField fx:id="campoNombre" promptText="Nombre" />
                <TextField fx:id="campoApellido" promptText="Apellido" />
                <TextField fx:id="campoDni" promptText="DNI (8 dígitos)" />
                <TextField fx:id="campoEmail" promptText="Email" />
                <DatePicker fx:id="campoFechaNacimiento" promptText="Fecha de nacimiento" maxWidth="Infinity" />
                <DatePicker fx:id="campoFechaContratacion" promptText="Fecha de contratación" maxWidth="Infinity" />
                <TextField fx:id="campoSalario" promptText="Salario base" />
                <ComboBox fx:id="comboEstado" promptText="Estado" maxWidth="Infinity" />
                <ComboBox fx:id="comboDepartamento" promptText="Departamento" maxWidth="Infinity" />
                <ComboBox fx:id="comboCargo" promptText="Cargo" maxWidth="Infinity" />
                <HBox spacing="8">
                    <Button text="Guardar" styleClass="button-primario" onAction="#onGuardar" />
                    <Button text="Actualizar" onAction="#onActualizar" />
                    <Button text="Eliminar" styleClass="button-peligro" onAction="#onEliminar" />
                    <Button text="Limpiar" onAction="#onLimpiar" />
                </HBox>
                <Label fx:id="labelMensaje" wrapText="true" />
            </VBox>
        </HBox>
    </center>
</BorderPane>
