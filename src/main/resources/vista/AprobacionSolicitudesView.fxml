<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rrhh.controlador.AprobacionController" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="encabezado">
            <Label text="Aprobación de Solicitudes" styleClass="titulo-seccion" HBox.hgrow="ALWAYS" />
            <Button text="Volver al menú" onAction="#onVolver" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16" />
            </padding>
            <TableView fx:id="tablaSolicitudes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colEmpleado" text="Empleado" prefWidth="200" />
                    <TableColumn fx:id="colPeriodo" text="Periodo" prefWidth="220" />
                    <TableColumn fx:id="colDias" text="Días hábiles" prefWidth="100" />
                </columns>
            </TableView>
            <HBox spacing="8">
                <Button text="Aprobar" styleClass="button-primario" onAction="#onAprobar" />
                <Button text="Rechazar" styleClass="button-peligro" onAction="#onRechazar" />
            </HBox>
            <Label fx:id="labelMensaje" wrapText="true" />
        </VBox>
    </center>
</BorderPane>
