<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rrhh.controlador.DepartamentoController" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="encabezado">
            <Label text="Gestión de Departamentos" styleClass="titulo-seccion" HBox.hgrow="ALWAYS" />
            <Button text="Volver al menú" onAction="#onVolver" />
        </HBox>
    </top>
    <center>
        <HBox spacing="16">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16" />
            </padding>
            <TableView fx:id="tablaDepartamentos" HBox.hgrow="ALWAYS" prefWidth="450">
                <columns>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180" />
                    <TableColumn fx:id="colPresupuesto" text="Presupuesto" prefWidth="120" />
                    <TableColumn fx:id="colGerente" text="Gerente" prefWidth="150" />
                </columns>
            </TableView>
            <VBox spacing="8" prefWidth="300" styleClass="tarjeta">
                <Label text="Datos del departamento" style="-fx-font-weight: bold;" />
                <TextField fx:id="campoNombre" promptText="Nombre" />
                <TextField fx:id="campoPresupuesto" promptText="Presupuesto" />
                <ComboBox fx:id="comboGerente" promptText="Gerente (opcional)" maxWidth="Infinity" />
                <HBox spacing="8">
                    <Button text="Guardar" styleClass="button-primario" onAction="#onGuardar" />
                    <Button text="Actualizar" onAction="#onActualizar" />
                    <Button text="Eliminar" styleClass="button-peligro" onAction="#onEliminar" />
                    <Button text="Limpiar" onAction="#onLimpiar" />
                </HBox>
                <Label fx:id="labelMensaje" wrapText="true" />
            </VBox>
        </HBox>
    </center>
</BorderPane>
